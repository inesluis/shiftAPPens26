<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">
    <persistence-unit name="shiftappensPU" transaction-type="RESOURCE_LOCAL">
        <class>org.example.jakartapp.entity.Ingredient</class>
        <class>org.example.jakartapp.entity.Recipe</class>
        <class>org.example.jakartapp.entity.Supermarket</class>
        <class>org.example.jakartapp.entity.Product</class>
        <class>org.example.jakartapp.entity.ProductPrice</class>
        <class>org.example.jakartapp.entity.RecipeIngredient</class>
        <class>org.example.jakartapp.entity.UserRecipe</class>
        <class>org.example.jakartapp.entity.UserRecipeProduct</class>
        <exclude-unlisted-classes>false</exclude-unlisted-classes>
    </persistence-unit>
</persistence>